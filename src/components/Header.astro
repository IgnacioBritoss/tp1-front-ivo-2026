---
const title = 'Quiniela Interactiva';
---
<header class="site-header">
  <div class="container header-inner">
    <div>
      <p class="eyebrow">TP Frontend con Astro</p>
      <h1>{title}</h1>
      <p class="subtitle">
        Mini app para generar jugadas, consultar estadísticas y sumar una sección de astro de la suerte.
      </p>
    </div>
    <button id="themeToggle" class="theme-toggle" type="button" aria-label="Cambiar tema">
      🌙 / ☀️
    </button>
  </div>
</header>
