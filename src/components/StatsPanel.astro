<section id="estadisticas" class="panel section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Sección 3</p>
      <h2>Estadísticas e historial</h2>
      <p>La página actualiza estos datos en tiempo real según las jugadas generadas.</p>
    </div>

    <div class="stats-grid">
      <article class="card stat-card">
        <span class="stat-label">Boletas jugadas</span>
        <strong id="statBoletas">0</strong>
      </article>
      <article class="card stat-card">
        <span class="stat-label">Números distintos</span>
        <strong id="statUnicos">0</strong>
      </article>
      <article class="card stat-card">
        <span class="stat-label">Número más repetido</span>
        <strong id="statTop">-</strong>
      </article>
    </div>

    <div class="history-grid">
      <article class="card">
        <h3>Historial</h3>
        <ul id="historialLista" class="history-list">
          <li>Todavía no se generaron jugadas.</li>
        </ul>
      </article>

      <article class="card">
        <h3>Top 5 números</h3>
        <ol id="topNumeros" class="top-list">
          <li>Esperando datos...</li>
        </ol>
      </article>
    </div>
  </div>
</section>
